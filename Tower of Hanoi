def tower(n, source, auxiliary, target):

    if n == 1:
        print("Move disk 1 from", source, "to", target)
        return

    tower(n-1, source, target, auxiliary)

    print("Move disk", n, "from", source, "to", target)

    tower(n-1, auxiliary, source, target)

tower(3, 'A', 'B', 'C')

