import math

def alphabeta(depth, index, isMax, values, alpha, beta):

    # Stop when depth reaches 3
    if depth == 3:
        return values[index]

    # Maximizer
    if isMax:
        best = -math.inf

        for i in range(2):
            value = alphabeta(
                depth + 1,
                index * 2 + i,
                False,
                values,
                alpha,
                beta
            )

            best = max(best, value)
            alpha = max(alpha, best)

            # Pruning
            if alpha >= beta:
                break

        return best

    # Minimizer
    else:
        best = math.inf

        for i in range(2):
            value = alphabeta(
                depth + 1,
                index * 2 + i,
                True,
                values,
                alpha,
                beta
            )

            best = min(best, value)
            beta = min(beta, best)

            # Pruning
            if alpha >= beta:
                break

        return best


values = [3, 5, 6, 9, 1, 2, 0, -1]

result = alphabeta(0, 0, True, values, -math.inf, math.inf)

print("Optimal Value is :", result)

